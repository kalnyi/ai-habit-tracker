{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PAT}"
      }
    },
    "postgres": {
      "type": "sse",
      "url": "http://localhost:8000/sse"
    },
    "filesystem": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c", "npx", "-y", "@modelcontextprotocol/server-filesystem", "."
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c", "npx", "-y", "@upstash/context7-mcp@latest"
      ]
    }
  }
}